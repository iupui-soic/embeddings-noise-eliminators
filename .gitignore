# =============================================================================
# .gitignore for embeddings-noise-eliminators
# =============================================================================

# --- Jupyter -----------------------------------------------------------------
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Papermill writes executed copies here; do not commit them
notebooks/.executed/

# --- Python ------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# --- Local dev environments --------------------------------------------------
.venv/
venv/
env/
.env

# --- OS / editors ------------------------------------------------------------
.DS_Store
*.swp
.vscode/
.idea/

# --- Data and run-time artifacts ---------------------------------------------
# Users keep raw radiographs here; we never commit them.
data/
datasets/
checkpoints/
models/

# All run-time outputs (parquets, figures, logs, executed notebooks,
# DINO-ResNet-50 weights downloaded by scripts/download_dino_resnet50.sh).
outputs/

# Manuscript LaTeX package — never committed to the public repo.
manuscript/

# --- Backwards-compat (paths from earlier layouts that no longer exist) ------
# Keep these so a stale checkout from before the v4-flatten refactor still
# behaves correctly until the user re-pulls.
v4_work/
v4/
